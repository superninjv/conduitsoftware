                  <p className="text-sm text-[var(--text-tertiary)] leading-relaxed flex-1">{app.desc}</p>
                  {app.external && app.href && (
                    <a href={app.href} target="_blank" rel="noopener noreferrer" className="mt-3 pt-3 border-t border-[var(--border-color)] text-xs font-medium text-conduit-500 hover:text-conduit-400 transition-colors inline-flex items-center gap-1">
                      Visit site
                      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5"><polyline points="9 18 15 12 9 6" /></svg>
                    </a>
                  )}
                </div>
              </AnimatedSection>
            ))}
