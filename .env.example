# Conduit Software Environment Variables
# Copy this to .env.local and fill in your values

# Email (Nodemailer SMTP)
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=contact@conduitsoftware.org
SMTP_PASS=your-app-password-here
CONTACT_EMAIL=contact@conduitsoftware.org

# Site
NEXT_PUBLIC_SITE_URL=https://conduitsoftware.org

# GitHub (optional — for bug report integration later)
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
